variable 	Ef equal "c_eatoms"
variable 	Efo equal $Ef
variable 	Efo equal -10584.7395640192f
variable	Cf equal 1.60217657e-16
variable 	A equal (${xdim}*${ydim})*1e-20
variable 	A equal (49.6021695188668*${ydim})*1e-20
variable 	A equal (49.6021695188668*28.6378259241072)*1e-20
variable 	SFE equal ((${Ef}-${Eo})*${Cf})/${A}
variable 	SFE equal ((-10584.7395640192-${Eo})*${Cf})/${A}
variable 	SFE equal ((-10584.7395640192--10597.6382170702)*${Cf})/${A}
variable 	SFE equal ((-10584.7395640192--10597.6382170702)*1.60217657e-16)/${A}
variable 	SFE equal ((-10584.7395640192--10597.6382170702)*1.60217657e-16)/1.42049829613936e-17
variable 	Efomj equal ${Ef}*${Cf}/${A}
variable 	Efomj equal -10584.7395640192*${Cf}/${A}
variable 	Efomj equal -10584.7395640192*1.60217657e-16/${A}
variable 	Efomj equal -10584.7395640192*1.60217657e-16/1.42049829613936e-17

####################################
print "Initial energy of atoms = ${Eo} eV"
Initial energy of atoms = -10597.6382170702 eV
print "Initial energy before twinning Efo = ${Ef} $Efomj" # in SFE in mJ/m^2"
Initial energy before twinning Efo = -10584.7395640192 -10584.7395640192fomj

#----------- for twin fault energy -----------------------
variable	Ndiscrt equal 30
variable    	i loop ${Ndiscrt}
variable    	i loop 30
label       	loop

variable 	xt_displace equal -1*(${latparam1}/sqrt(6)*${i}/${Ndiscrt})
variable 	xt_displace equal -1*(4.05000018187522/sqrt(6)*${i}/${Ndiscrt})
variable 	xt_displace equal -1*(4.05000018187522/sqrt(6)*1/${Ndiscrt})
variable 	xt_displace equal -1*(4.05000018187522/sqrt(6)*1/30)
variable 	Bxt_displace equal 1.0+${i}/${Ndiscrt}
variable 	Bxt_displace equal 1.0+1/${Ndiscrt}
variable 	Bxt_displace equal 1.0+1/30

displace_atoms 	top2 move ${xt_displace} 0.0 0.0 units box
displace_atoms 	top2 move -0.0551135216876298 0.0 0.0 units box
Displacing atoms ...

fix 		1 all setforce 0 0 NULL
min_style 	cg
minimize 	0.0 1e-8 20000 20000

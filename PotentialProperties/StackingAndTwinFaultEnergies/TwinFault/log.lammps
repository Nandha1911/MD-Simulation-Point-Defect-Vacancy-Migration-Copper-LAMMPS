#####################################################################################################################
# Course: Theory, Modelling, and Simulation of Microstructures (TMS) - Summer semester 2021
# Tutors: Dr. Arun Prakash, Vimal Muthusamy
# Description: Input file for Twin Fault Energy (TFE) of your element
# Originally created by Richard Glaze, 2014. Modified by S. Roy, 2018
######################################################################################################################

# --------------------- INITIALIZAITION ---------------------


clear
units		metal
dimension	3
boundary	p p s
atom_style	atomic
variable 	latparam1 equal 4.05000018187522    ### provide the lattice constant from your calculation
variable 	x_displace equal -1*(${latparam1}/sqrt(6))
variable 	x_displace equal -1*(4.05000018187522/sqrt(6))
variable 	xdim equal ${latparam1}*sqrt(6)/2*10
variable 	xdim equal 4.05000018187522*sqrt(6)/2*10
variable 	ydim equal ${latparam1}*sqrt(2)/2*10
variable 	ydim equal 4.05000018187522*sqrt(2)/2*10
variable 	atomjiggle equal 1.0e-5
variable 	Bx_displace equal 1.0

# --------------------- ATOM DEFINITION ---------------------
lattice		fcc ${latparam1}
lattice		fcc 4.05000018187522
Lattice spacing in x,y,z = 4.0500002 4.0500002 4.0500002
region		1 block -.001 ${xdim} -.001 ${ydim} -.001 16.5 units box
region		1 block -.001 49.6021695188668 -.001 ${ydim} -.001 16.5 units box
region		1 block -.001 49.6021695188668 -.001 28.6378259241072 -.001 16.5 units box
region 		2 block -.001 ${xdim} -.001 ${ydim} 16.5 36.5808 units box
region 		2 block -.001 49.6021695188668 -.001 ${ydim} 16.5 36.5808 units box
region 		2 block -.001 49.6021695188668 -.001 28.6378259241072 16.5 36.5808 units box
region 		3 block -.001 ${xdim} -.001 ${ydim} 19.5 36.5808 units box
region 		3 block -.001 49.6021695188668 -.001 ${ydim} 19.5 36.5808 units box
region 		3 block -.001 49.6021695188668 -.001 28.6378259241072 19.5 36.5808 units box
region		whole block 0 ${xdim} 0 ${ydim} 0 36.5808 units box
region		whole block 0 49.6021695188668 0 ${ydim} 0 36.5808 units box
region		whole block 0 49.6021695188668 0 28.6378259241072 0 36.5808 units box
#the -.001 in the -x and -y and lower limit of region 1 are only to overcome a simple numerical issue but can be considered 0
create_box 	1 whole
Created orthogonal box = (0.0000000 0.0000000 0.0000000) to (49.602170 28.637826 36.580800)
  2 by 2 by 2 MPI processor grid
lattice 	fcc ${latparam1} orient x 1 1 2 orient y -1 1 0 orient z -1 -1 1
lattice 	fcc 4.05000018187522 orient x 1 1 2 orient y -1 1 0 orient z -1 -1 1

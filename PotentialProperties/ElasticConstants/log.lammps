variable tmp equal pxx
variable pxx0 equal ${tmp}
variable pxx0 equal -1.42808542573944e-11
variable tmp equal pyy
variable pyy0 equal ${tmp}
variable pyy0 equal -7.67595916334951e-11
variable tmp equal pzz
variable pzz0 equal ${tmp}
variable pzz0 equal 1.42808542573944e-11
variable tmp equal pyz
variable pyz0 equal ${tmp}
variable pyz0 equal -6.58258125926775e-12
variable tmp equal pxz
variable pxz0 equal ${tmp}
variable pxz0 equal -2.23138347771788e-13
variable tmp equal pxy
variable pxy0 equal ${tmp}
variable pxy0 equal 5.80159704206649e-12

variable tmp equal lx
variable lx0 equal ${tmp}
variable lx0 equal 8.10000036375043
variable tmp equal ly
variable ly0 equal ${tmp}
variable ly0 equal 12.1500005456256
variable tmp equal lz
variable lz0 equal ${tmp}
variable lz0 equal 16.2000007275009

# These formulas define the derivatives w.r.t. strain components
# Constants uses $, variables use v_
variable d1 equal -(v_pxx1-${pxx0})/(v_delta/v_len0)*${cfac}
variable d1 equal -(v_pxx1--1.42808542573944e-11)/(v_delta/v_len0)*${cfac}
variable d1 equal -(v_pxx1--1.42808542573944e-11)/(v_delta/v_len0)*0.0001
variable d2 equal -(v_pyy1-${pyy0})/(v_delta/v_len0)*${cfac}
variable d2 equal -(v_pyy1--7.67595916334951e-11)/(v_delta/v_len0)*${cfac}
variable d2 equal -(v_pyy1--7.67595916334951e-11)/(v_delta/v_len0)*0.0001
variable d3 equal -(v_pzz1-${pzz0})/(v_delta/v_len0)*${cfac}
variable d3 equal -(v_pzz1-1.42808542573944e-11)/(v_delta/v_len0)*${cfac}
variable d3 equal -(v_pzz1-1.42808542573944e-11)/(v_delta/v_len0)*0.0001
variable d4 equal -(v_pyz1-${pyz0})/(v_delta/v_len0)*${cfac}
variable d4 equal -(v_pyz1--6.58258125926775e-12)/(v_delta/v_len0)*${cfac}
variable d4 equal -(v_pyz1--6.58258125926775e-12)/(v_delta/v_len0)*0.0001
variable d5 equal -(v_pxz1-${pxz0})/(v_delta/v_len0)*${cfac}
variable d5 equal -(v_pxz1--2.23138347771788e-13)/(v_delta/v_len0)*${cfac}
variable d5 equal -(v_pxz1--2.23138347771788e-13)/(v_delta/v_len0)*0.0001
variable d6 equal -(v_pxy1-${pxy0})/(v_delta/v_len0)*${cfac}
variable d6 equal -(v_pxy1-5.80159704206649e-12)/(v_delta/v_len0)*${cfac}
variable d6 equal -(v_pxy1-5.80159704206649e-12)/(v_delta/v_len0)*0.0001

displace_atoms all random ${atomjiggle} ${atomjiggle} ${atomjiggle} 87287 units box
displace_atoms all random 1e-05 ${atomjiggle} ${atomjiggle} 87287 units box
displace_atoms all random 1e-05 1e-05 ${atomjiggle} 87287 units box
displace_atoms all random 1e-05 1e-05 1e-05 87287 units box
Displacing atoms ...

# Write restart
unfix 3
write_restart restart.equil
System init for write_restart ...

# uxx Perturbation

variable dir equal 1
include displace.mod
# NOTE: This script should not need to be
# modified. See in.elastic for more info.
#
# Find which reference length to use

if "${dir} == 1" then    "variable len0 equal ${lx0}"
variable len0 equal ${lx0}
variable len0 equal 8.10000036375043
if "${dir} == 2" then    "variable len0 equal ${ly0}"
if "${dir} == 3" then    "variable len0 equal ${lz0}"
if "${dir} == 4" then    "variable len0 equal ${lz0}"
if "${dir} == 5" then    "variable len0 equal ${lz0}"
if "${dir} == 6" then    "variable len0 equal ${ly0}"

# Reset box and simulation parameters

clear
box tilt large
read_restart restart.equil

# ------------------------ FORCE FIELDS ------------------------------
pair_style      eam/alloy ### TYPE OF POTENTIAL (eam (OR) eam/alloy)
pair_coeff      *  * /home03/nm95xule/TMS_SS2022Nan/Mishin_updated-Al-Co-2013.eam.alloy Al  ### POTENTIAL FILENAME

variable        natoms equal "count(all)"
variable        ecoh equal "pe/v_natoms"


# ------------------------- SETTINGS ---------------------------------
neighbor     	2.0 bin
neigh_modify 	delay 3
timestep 	$t
timestep 	0.0001
thermo 		1
thermo_style 	custom step time temp etotal press pxx pyy pzz pxy pyz pxz lx ly lz fnorm v_ecoh

velocity 	all create 300.0 16723 rot yes dist gaussian


#--------------- ENERGY EQUILIBRATION --------------------------
fix 		2 all temp/rescale 10 300.0 300.0 1.0 0.5
fix 		1 all nve

run 		$r
run 		10000
